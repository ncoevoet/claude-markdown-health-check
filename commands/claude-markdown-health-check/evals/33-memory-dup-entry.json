{
  "id": "33-memory-dup-entry",
  "command": "claude-markdown-health-check",
  "fixture": {
    "kind": "claude-tree",
    "dir": "tests/fixtures/memory-dup-entry",
    "needs_home_override": true,
    "scanners": ["scan-graph"]
  },
  "grader": { "method": "code" },
  "success_criteria": {
    "must_detect": [ { "tag": "MEMORY-DUP-ENTRY", "path_substring": "MEMORY.md" } ],
    "must_not_flag": ["MEMORY-DEAD-LINK"],
    "expect_clean": false
  },
  "expected_behavior": [
    "scan-graph.sh emits [MEMORY-DUP-ENTRY] for a MEMORY.md that links note.md more than once"
  ]
}
