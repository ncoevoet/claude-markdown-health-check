{
  "id": "83-history-signals",
  "command": "claude-markdown-health-check",
  "fixture": {
    "kind": "synthetic-jsonl",
    "dir": "tests/fixtures/history-signals",
    "needs_home_override": true,
    "scanners": ["scan-history"]
  },
  "grader": { "method": "code" },
  "success_criteria": {
    "history_assertions": [
      { "jq": ".hookEvents.guard.total", "equals": 4 },
      { "jq": ".hookEvents.guard.failures", "equals": 2 },
      { "jq": "(.hookEvents.guard.events | length)", "equals": 1 },
      { "jq": ".skills[\"my-skill\"].invokes", "equals": 2 },
      { "jq": ".skills[\"my-skill\"].sessions", "equals": 2 },
      { "jq": ".agentSpawns.Explore.count", "equals": 2 },
      { "jq": ".tokenUsage[\"sess-A\"].input", "equals": 200 },
      { "jq": ".tokenUsage[\"sess-A\"].output", "equals": 900 },
      { "jq": ".tokenUsage[\"sess-A\"].turns", "equals": 2 },
      { "jq": ".denials.count", "equals": 1 },
      { "jq": "(.corrections | length)", "equals": 1 },
      { "jq": ".skillLedger[\"my-skill\"].usageCount", "equals": 5 },
      { "jq": ".skills[\"ancient-skill\"]", "equals": null }
    ]
  },
  "expected_behavior": [
    "scan-history.sh aggregates the synthetic transcript: guard hook total=4 failures=2 over one PreToolUse event",
    "my-skill folds 2 invokes across 2 sessions; the agents:my-skill ledger entry folds into my-skill (usageCount 3+2=5)",
    "sess-A token usage sums to input 200 / output 900 over 2 turns; one denial and one correction are counted",
    "the __TS_OLD__ ancient-skill event is outside the window and is excluded from .skills"
  ]
}
