{
  "id": "57-plugin-bad-version",
  "command": "claude-markdown-health-check",
  "fixture": {
    "kind": "claude-tree",
    "dir": "tests/fixtures/plugin-bad-version",
    "needs_home_override": false,
    "scanners": ["scan-graph"]
  },
  "grader": { "method": "code" },
  "success_criteria": {
    "must_detect": [ { "tag": "PLUGIN-BAD-VERSION", "path_substring": "plugin.json" } ],
    "must_not_flag": ["PLUGIN-MISPLACED-DIR", "PLUGIN-ABS-PATH"],
    "expect_clean": false
  },
  "expected_behavior": [
    "scan-graph.sh emits [PLUGIN-BAD-VERSION] because plugin.json version '1.0' is not semantic (MAJOR.MINOR.PATCH)"
  ]
}
