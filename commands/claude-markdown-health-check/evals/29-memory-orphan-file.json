{
  "id": "29-memory-orphan-file",
  "command": "claude-markdown-health-check",
  "fixture": {
    "kind": "claude-tree",
    "dir": "tests/fixtures/memory-orphan-file",
    "needs_home_override": true,
    "scanners": ["scan-graph"]
  },
  "grader": { "method": "code" },
  "success_criteria": {
    "must_detect": [ { "tag": "MEMORY-ORPHAN-FILE", "path_substring": "stray" } ],
    "must_not_flag": ["MEMORY-DEAD-LINK"],
    "expect_clean": false
  },
  "expected_behavior": [
    "scan-graph.sh emits [MEMORY-ORPHAN-FILE] for stray.md, which no MEMORY.md entry links to"
  ]
}
