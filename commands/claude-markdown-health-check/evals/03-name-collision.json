{
  "id": "03-name-collision",
  "command": "claude-markdown-health-check",
  "fixture": {
    "kind": "claude-tree",
    "dir": "tests/fixtures/name-collision",
    "needs_home_override": false,
    "scanners": ["validate-skills"]
  },
  "grader": { "method": "code" },
  "success_criteria": {
    "must_detect": [ { "tag": "NAME-COLLISION", "path_substring": "deploy" } ],
    "must_not_flag": ["MISSING-DESC"],
    "expect_clean": false
  },
  "expected_behavior": [
    "validate-skills.sh emits [NAME-COLLISION] because deploy exists as both skills/deploy/SKILL.md and commands/deploy.md"
  ]
}
